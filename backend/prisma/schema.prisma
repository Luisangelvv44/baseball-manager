generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Division {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(50)
  teams Team[]
}

model Team {
  id                   Int     @id @default(autoincrement())
  name                 String  @db.VarChar(100)
  division_id          Int?
  is_user_team         Boolean @default(false)
  budget               Decimal @default(0) @db.Decimal(14, 2)
  reputation           Int     @default(50)
  wins                 Int     @default(0)
  losses               Int     @default(0)
  runs_scored          Int     @default(0)
  runs_allowed         Int     @default(0)
  bid_aggressiveness   Float   @default(0.10)
  min_growth_threshold Float   @default(1.5)
  fan_base             Int     @default(0)
  stadium_floors       Int     @default(1)

  division            Division?          @relation(fields: [division_id], references: [id])
  players             Player[]
  finances            Finance[]
  scouts              Scout[]
  coaches             Coach[]
  stadium_sections    StadiumSection[]
  home_games          GameSchedule[]     @relation("HomeTeam")
  away_games          GameSchedule[]     @relation("AwayTeam")
  game_lineups        GameLineup[]
  team_lineups        TeamLineup[]
  batting_events      GameEvent[]        @relation("BattingTeam")
  won_auctions        FreeAgentAuction[] @relation("AuctionWinner")
  auction_bids        AuctionBid[]
  broadcast_offers    BroadcastOffer[]
  broadcast_contracts BroadcastContract[]
  playoff_home        PlayoffSeries[]     @relation("PlayoffHome")
  playoff_away        PlayoffSeries[]     @relation("PlayoffAway")
  playoff_won         PlayoffSeries[]     @relation("PlayoffWinner")
  trades_proposed     Trade[]             @relation("TradeProposer")
  trades_received     Trade[]             @relation("TradeRecipient")
}

model Player {
  id                       Int     @id @default(autoincrement())
  first_name               String  @db.VarChar(50)
  last_name                String  @db.VarChar(50)
  age                      Int
  position                 String  @db.VarChar(10)
  potential_coefficient    Int
  growth_age               Int
  current_skill            Int
  salary                   Decimal @db.Decimal(12, 2)
  contract_years_remaining Int     @default(1)
  rookie_contract          Boolean @default(false)
  rookie_seasons           Int     @default(0)
  team_id                  Int?
  status                   String  @default("active") @db.VarChar(20)
  injury_days_remaining    Int     @default(0)

  team         Team?            @relation(fields: [team_id], references: [id])
  coach        Coach?
  auctions     FreeAgentAuction[]
  game_lineups GameLineup[]
  team_lineups TeamLineup[]
  game_events  GameEvent[]      @relation("PlayerEvent")
  trade_items  TradeItem[]

  @@index([team_id])
  @@index([status])
}

model Season {
  id          Int    @id @default(autoincrement())
  year        Int
  current_day Int    @default(1)
  total_days  Int    @default(0)
  status      String @default("active") @db.VarChar(20)

  schedule            GameSchedule[]
  auctions            FreeAgentAuction[]
  broadcast_offers    BroadcastOffer[]
  broadcast_contracts BroadcastContract[]
  playoff_series      PlayoffSeries[]
  draft               Draft?
  season_record       SeasonRecord?
  trades              Trade[]
}

model SeasonRecord {
  id            Int     @id @default(autoincrement())
  season_id     Int     @unique
  year          Int
  champion_name String? @db.VarChar(100)
  standings     Json

  season Season @relation(fields: [season_id], references: [id])

  @@map("season_records")
}


model GameSchedule {
  id                Int     @id @default(autoincrement())
  season_id         Int?
  day_number        Int
  home_team_id      Int?
  away_team_id      Int?
  home_score        Int?
  away_score        Int?
  status            String  @default("scheduled") @db.VarChar(20)
  is_user_game      Boolean @default(false)
  playoff_series_id Int?

  season         Season?       @relation(fields: [season_id], references: [id])
  home_team      Team?         @relation("HomeTeam", fields: [home_team_id], references: [id])
  away_team      Team?         @relation("AwayTeam", fields: [away_team_id], references: [id])
  playoff_series PlayoffSeries? @relation(fields: [playoff_series_id], references: [id])
  game_lineups   GameLineup[]
  game_events    GameEvent[]

  @@map("schedule")
  @@index([season_id, day_number])
}

model PlayoffSeries {
  id           Int    @id @default(autoincrement())
  season_id    Int
  round        Int
  series_order Int
  home_team_id Int
  away_team_id Int
  home_wins    Int    @default(0)
  away_wins    Int    @default(0)
  wins_needed  Int    @default(2)
  status       String @default("active")
  winner_id    Int?

  season    Season        @relation(fields: [season_id], references: [id])
  home_team Team          @relation("PlayoffHome", fields: [home_team_id], references: [id])
  away_team Team          @relation("PlayoffAway", fields: [away_team_id], references: [id])
  winner    Team?         @relation("PlayoffWinner", fields: [winner_id], references: [id])
  games     GameSchedule[]

  @@map("playoff_series")
}

model StadiumSection {
  id               Int     @id @default(autoincrement())
  team_id          Int?
  row_pos          Int
  col_pos          Int
  section_type     String  @db.VarChar(20)
  label            String? @db.VarChar(50)
  price_per_ticket Decimal @default(0) @db.Decimal(8, 2)
  upgrade_level    Int     @default(0)
  capacity         Int     @default(0)

  team Team? @relation(fields: [team_id], references: [id])

  @@map("stadium_sections")
  @@index([team_id])
}

model Finance {
  id          Int      @id @default(autoincrement())
  team_id     Int?
  season_day  Int?
  type        String   @db.VarChar(30)
  amount      Decimal  @db.Decimal(14, 2)
  description String?
  created_at  DateTime @default(now())

  team Team? @relation(fields: [team_id], references: [id])

  @@map("finances")
  @@index([team_id])
}

model Scout {
  id              Int     @id @default(autoincrement())
  team_id         Int?
  name            String? @db.VarChar(100)
  skill_level     Int     @default(50)
  budget_assigned Decimal @default(0) @db.Decimal(10, 2)
  active_mission  Boolean @default(false)
  mission_end_day Int?
  target_position String? @db.VarChar(10)

  team Team? @relation(fields: [team_id], references: [id])

  @@map("scouts")
}

model GameLineup {
  id            Int     @id @default(autoincrement())
  game_id       Int?
  team_id       Int?
  player_id     Int?
  batting_order Int?
  position      String? @db.VarChar(10)

  game   GameSchedule? @relation(fields: [game_id], references: [id])
  team   Team?         @relation(fields: [team_id], references: [id])
  player Player?       @relation(fields: [player_id], references: [id])

  @@map("game_lineups")
}

model GameEvent {
  id              Int     @id @default(autoincrement())
  game_id         Int?
  inning          Int?
  half            String? @db.VarChar(4)
  batting_team_id Int?
  player_id       Int?
  result          String? @db.VarChar(10)
  outs_after      Int?
  runs_scored     Int     @default(0)
  event_order     Int?

  game         GameSchedule? @relation(fields: [game_id], references: [id])
  batting_team Team?         @relation("BattingTeam", fields: [batting_team_id], references: [id])
  player       Player?       @relation("PlayerEvent", fields: [player_id], references: [id])

  @@map("game_events")
  @@index([game_id])
}

model TeamLineup {
  id            Int     @id @default(autoincrement())
  team_id       Int
  player_id     Int
  batting_order Int?
  is_pitcher    Boolean @default(false)
  rotation_slot Int?

  team   Team   @relation(fields: [team_id], references: [id])
  player Player @relation(fields: [player_id], references: [id])

  @@map("team_lineup")
  @@index([team_id])
}

model FreeAgentAuction {
  id              Int      @id @default(autoincrement())
  player_id       Int
  season_id       Int
  status          String   @default("active") @db.VarChar(20)
  start_day       Int
  last_bid_day    Int?
  closes_on_day   Int?
  winning_team_id Int?
  created_at      DateTime @default(now())

  player       Player     @relation(fields: [player_id], references: [id])
  season       Season     @relation(fields: [season_id], references: [id])
  winning_team Team?      @relation("AuctionWinner", fields: [winning_team_id], references: [id])
  bids         AuctionBid[]

  @@map("free_agent_auctions")
  @@index([status])
  @@index([closes_on_day])
}

model AuctionBid {
  id         Int      @id @default(autoincrement())
  auction_id Int
  team_id    Int
  amount     Decimal  @db.Decimal(14, 2)
  years      Int      @default(1)
  season_day Int
  created_at DateTime @default(now())

  auction FreeAgentAuction @relation(fields: [auction_id], references: [id])
  team    Team             @relation(fields: [team_id], references: [id])

  @@map("auction_bids")
  @@index([auction_id])
}

model BroadcastCompany {
  id            Int     @id @default(autoincrement())
  name          String  @db.VarChar(100)
  type          String  @db.VarChar(5)
  price_per_fan Decimal @db.Decimal(6, 4)

  offers    BroadcastOffer[]
  contracts BroadcastContract[]

  @@map("broadcast_companies")
}

model BroadcastOffer {
  id            Int      @id @default(autoincrement())
  company_id    Int
  team_id       Int
  season_id     Int
  seasons       Int
  price_per_fan Decimal  @db.Decimal(6, 4)
  status        String   @db.VarChar(20)
  expires_day   Int
  created_at    DateTime @default(now())

  company BroadcastCompany @relation(fields: [company_id], references: [id])
  team    Team             @relation(fields: [team_id], references: [id])
  season  Season           @relation(fields: [season_id], references: [id])

  @@map("broadcast_offers")
  @@index([team_id])
  @@index([status])
}

model BroadcastContract {
  id                Int      @id @default(autoincrement())
  company_id        Int
  team_id           Int
  seasons_total     Int
  seasons_remaining Int
  price_per_fan     Decimal  @db.Decimal(6, 4)
  signed_season_id  Int
  created_at        DateTime @default(now())

  company BroadcastCompany @relation(fields: [company_id], references: [id])
  team    Team             @relation(fields: [team_id], references: [id])
  season  Season           @relation(fields: [signed_season_id], references: [id])

  @@map("broadcast_contracts")
  @@index([team_id])
}

model Coach {
  id                 Int     @id @default(autoincrement())
  team_id            Int
  name               String  @db.VarChar(100)
  specialty          String  @db.VarChar(20)
  skill_level        Int
  salary             Int
  assigned_player_id Int?    @unique

  team            Team    @relation(fields: [team_id], references: [id])
  assigned_player Player? @relation(fields: [assigned_player_id], references: [id])

  @@map("coaches")
  @@index([team_id])
}

model Draft {
  id           Int             @id @default(autoincrement())
  season_id    Int             @unique
  status       String          @default("active") @db.VarChar(20)
  current_pick Int             @default(1)
  pick_order   Json

  season    Season          @relation(fields: [season_id], references: [id])
  prospects DraftProspect[]

  @@map("drafts")
}

model DraftProspect {
  id                   Int    @id @default(autoincrement())
  draft_id             Int
  name                 String @db.VarChar(100)
  position             String @db.VarChar(10)
  age                  Int
  current_skill        Int
  potential_coefficient Int
  growth_age           Int
  picked_by_team_id    Int?
  pick_number          Int?

  draft Draft @relation(fields: [draft_id], references: [id])

  @@map("draft_prospects")
  @@index([draft_id])
}

model Trade {
  id                Int      @id @default(autoincrement())
  season_id         Int
  proposer_team_id  Int
  recipient_team_id Int
  status            String   @default("pending") @db.VarChar(20) // pending | accepted | rejected | cancelled | expired
  cash_offered      Decimal  @default(0) @db.Decimal(14, 2) // proposer -> recipient
  cash_requested    Decimal  @default(0) @db.Decimal(14, 2) // recipient -> proposer
  created_day       Int
  expires_day       Int?
  resolved_day      Int?
  created_at        DateTime @default(now())

  season         Season      @relation(fields: [season_id], references: [id])
  proposer_team  Team        @relation("TradeProposer", fields: [proposer_team_id], references: [id])
  recipient_team Team        @relation("TradeRecipient", fields: [recipient_team_id], references: [id])
  items          TradeItem[]

  @@map("trades")
  @@index([status])
  @@index([recipient_team_id])
  @@index([proposer_team_id])
}

model TradeItem {
  id           Int    @id @default(autoincrement())
  trade_id     Int
  player_id    Int
  from_team_id Int // equipo dueño del jugador al momento de proponer

  trade  Trade  @relation(fields: [trade_id], references: [id])
  player Player @relation(fields: [player_id], references: [id])

  @@map("trade_items")
  @@index([trade_id])
  @@index([player_id])
}

model NewsItem {
  id         Int      @id @default(autoincrement())
  type       String   @db.VarChar(20)
  headline   String   @db.VarChar(500)
  season_day Int      @default(0)
  season_id  Int?
  created_at DateTime @default(now())

  @@map("news_items")
  @@index([season_day])
  @@index([season_id])
}
